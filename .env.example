# Servidor
NODE_ENV=production
PORT=3000
PUBLIC_APP_URL=https://app.seudominio.com

# Banco do ambiente
DATABASE_URL=postgresql://usuario:senha@host-pooler.neon.tech/neondb?sslmode=require

# Segurança: gere valores únicos para cada instalação
JWT_SECRET=substitua-por-um-segredo-aleatorio-com-mais-de-32-caracteres
# Exemplo de geração: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SECRETS_ENCRYPTION_KEY=chave-base64-de-exatos-32-bytes
ADMIN_EMAIL=admin@seudominio.com
ADMIN_INITIAL_PASSWORD=troque-no-primeiro-acesso
ADMIN_NAME=Administrador

# WhatsApp / Evolution
EVOLUTION_API_URL=https://sua-evolution.onrender.com
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=cliente-identificador
EVOLUTION_TIMEOUT_MS=15000

# Instagram / Meta
INSTAGRAM_GRAPH_API_URL=https://graph.facebook.com
INSTAGRAM_APP_SECRET=
INSTAGRAM_VERIFY_TOKEN=

# IA: somente backend, nunca use VITE_* para chaves secretas
GROQ_API_URL=https://api.groq.com/openai/v1
GROQ_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# APIs do painel central para provisionar recursos dos clientes
RENDER_API_KEY=
NEON_API_KEY=
